      <input
        ref={fileInputRef}
        type="file"
        accept=".xlsx,.xls,.csv"
        style={{ display: "none" }}
        onChange={handleExcelImport}
      />

      <div className="admin-pronos-top admin-photo-top-card">
        <div className="admin-pronos-title">
          <h1>Admin pronostics</h1>
          <p>Meme presentation que la page Pronos, mais ici tu geres les journees, les matchs et les bonus.</p>
        </div>

        <div className="admin-pronos-actions">
          <button className="admin-btn green" type="button" onClick={() => fileInputRef.current?.click()}>
            Importer Excel
          </button>

          <button className="admin-btn" type="button" onClick={previousJournee}>
            Journee avant
          </button>

          <select
            className="admin-select"
            value={selectedJournee.id}
            onChange={(e) => setSelectedJourneeId(e.target.value)}
          >
            {journees.map((j) => (
              <option key={j.id} value={j.id}>
                {j.title}
              </option>
            ))}
          </select>

          <button className="admin-btn" type="button" onClick={nextJournee}>
            Journee apres
          </button>

          <button className="admin-btn" type="button" onClick={addJournee}>
            Ajouter journee
          </button>

          <button className="admin-btn gold" type="button" onClick={toggleLock}>
            {selectedJournee.locked ? "Rouvrir journee" : "Fermer journee"}
          </button>

          <button className="admin-btn green" type="button" onClick={saveAll}>
            Sauvegarder
          </button>
        </div>

        <div className="admin-message">
          {message}
        </div>
      </div>

      <div className="admin-favorite-card">
        <div className="admin-favorite-left">
          <h2>Date butoir club favori</h2>
          <p>Definis jusqu'a quand les joueurs peuvent choisir ou modifier leur equipe favorite.</p>

          <input
            className="admin-lock-input"
            type="datetime-local"
            value={favoriteDeadline}
            onChange={(e) => setFavoriteDeadline(e.target.value)}
          />

          <div className="admin-deadline-pill">
            {favoriteDeadline
              ? "Date butoir : " + formatFavoriteDeadline(favoriteDeadline)
              : "Aucune date butoir : choix encore ouvert"}
          </div>

          <div className="admin-deadline-note">
            {favoriteDeadlineMessage}
          </div>
        </div>

        <div className="admin-favorite-actions">
          <button className="admin-btn green" type="button" onClick={validateFavoriteDeadline}>
            Valider date butoir
          </button>

          <button className="admin-btn red" type="button" onClick={clearFavoriteDeadline}>
            Effacer
          </button>
        </div>
      </div>

      <div className="section-head">
        <h2>Matchs Ligue 1 - {selectedJournee.title}</h2>
        <span>{matches.length} matchs</span>
      </div>

      <div className="admin-pronos-actions" style={{ marginBottom: 16 }}>
        <button className="admin-btn green" type="button" onClick={addMatch}>
          Ajouter un match Ligue 1
        </button>
      </div>

      <div className="admin-match-grid">
        {matches.map((match, index) => {
          const blocked = match.status === "Bloque";

          return (
            <div key={match.id} className={`admin-match-card ${blocked ? "blocked" : ""}`}>
              <div className="admin-match-top">
                <div className="admin-number">{index + 1}</div>

                <button
                  type="button"
                  className={`admin-status-btn ${blocked ? "blocked" : ""}`}
                  onClick={() => toggleMatchStatus(match.id)}
                >
                  {blocked ? "Bloque" : "Ouvert"}
                </button>
              </div>

              <div className="admin-fields">
                <label>
                  Equipe domicile
                  <input
                    className="admin-input"
                    value={match.home || ""}
                    onChange={(e) => updateMatch(match.id, { home: e.target.value })}
                    placeholder="RC Lens"
                  />
                </label>

                <label>
                  Equipe exterieur
                  <input
                    className="admin-input"
                    value={match.away || ""}
                    onChange={(e) => updateMatch(match.id, { away: e.target.value })}
                    placeholder="OL"
                  />
                </label>

                <div className="admin-two">
                  <label>
                    Date
                    <input
                      className="admin-input"
                      type="date"
                      value={toDateInputValue(match.date)}
                      onChange={(e) => updateMatch(match.id, { date: e.target.value })}
                    />
                  </label>

                  <label>
                    Heure
                    <input
                      className="admin-input"
                      type="time"
                      value={toTimeInputValue(match.time)}
                      onChange={(e) => updateMatch(match.id, { time: e.target.value })}
                    />
                  </label>
                </div>

                <label>
                  Resultat final
                  <div className="score-row">
                    <input
                      className="admin-input"
                      type="number"
                      min="0"
                      value={match.homeScore || ""}
                      onChange={(e) => updateMatch(match.id, { homeScore: e.target.value })}
                      placeholder="0"
                    />
                    <strong>-</strong>
                    <input
                      className="admin-input"
                      type="number"
                      min="0"
                      value={match.awayScore || ""}
                      onChange={(e) => updateMatch(match.id, { awayScore: e.target.value })}
                      placeholder="0"
                    />
                  </div>
                </label>
              </div>

              <div className="admin-card-actions">
                <button
                  type="button"
                  className={match.adminValidated ? "admin-validate-btn validated" : "admin-validate-btn"}
                  onClick={() => validateAdminMatch(match.id)}
                >
                  {match.adminValidated ? "Validé" : "Valider"}
                </button>

                
              </div>
            </div>
          );
        })}
      </div>

      <div className="section-head">
        <h2>Les 3 matchs bonus - {selectedJournee.title}</h2>
        <span>3 bonus modifiables</span>
      </div>

      <div className="admin-match-grid">
        {bonus.map((match, index) => (
          <div key={match.id} className="admin-match-card bonus">
            <div className="admin-match-top">
              <div className="admin-number">{index + 1}</div>
              <span className="admin-pill">Bonus</span>
            </div>

            <div className="admin-fields">
              <label>
                Competition
                <input
                  className="admin-input"
                  value={match.league || ""}
                  onChange={(e) => updateBonus(match.id, { league: e.target.value })}
                  placeholder="Premier League"
                />
              </label>

              <label>
                Equipe domicile
                <input
                  className="admin-input"
                  value={match.home || ""}
                  onChange={(e) => updateBonus(match.id, { home: e.target.value })}
                  placeholder="Liverpool"
                />
              </label>

              <label>
                Equipe exterieur
                <input
                  className="admin-input"
                  value={match.away || ""}
                  onChange={(e) => updateBonus(match.id, { away: e.target.value })}
                  placeholder="Chelsea"
                />
              </label>

              <div className="admin-two">
                <label>
                  Date
                  <input
                    className="admin-input"
                    type="date"
                    value={toDateInputValue(match.date)}
                    onChange={(e) => updateBonus(match.id, { date: e.target.value })}
                  />
                </label>

                <label>
                  Heure
                  <input
                    className="admin-input"
                    type="time"
                    value={toTimeInputValue(match.time)}
                    onChange={(e) => updateBonus(match.id, { time: e.target.value })}
                  />
                </label>
              </div>

              <label>
                Resultat final bonus
                <div className="score-row">
                  <input
                    className="admin-input"
                    type="number"
                    min="0"
                    value={match.homeScore || ""}
                    onChange={(e) => updateBonus(match.id, { homeScore: e.target.value })}
                    placeholder="0"
                  />
                  <strong>-</strong>
                  <input
                    className="admin-input"
                    type="number"
                    min="0"
                    value={match.awayScore || ""}
                    onChange={(e) => updateBonus(match.id, { awayScore: e.target.value })}
                    placeholder="0"
                  />
                </div>
              </label>
            </div>

            <div className="admin-card-actions">
              <button
                  type="button"
                  className={match.adminValidated ? "admin-validate-btn validated" : "admin-validate-btn"}
                  onClick={() => validateAdminMatch(match.id)}
                >
                  {match.adminValidated ? "Validé" : "Valider"}
                </button>

              <button
                className="red"
                type="button"
                onClick={() =>
                  updateBonus(match.id, {
                    league: "",
                    home: "",
                    away: "",
                    date: "",
                    time: "",
                    homeScore: "",
                    awayScore: ""
                  })
                }
              >
                Effacer
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}