          font-weight: 950;
        }

        .section-head {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin: 28px 0 14px;
        }

        .section-head h2 {
          margin: 0;
          font-size: 26px;
          font-weight: 950;
        }

        .section-head span {
          color: #b6c2d9;
          font-weight: 900;
        }

        .admin-match-grid {
          display: grid;
          grid-template-columns: repeat(3, minmax(0, 1fr));
          gap: 16px;
        }

        .admin-match-card {
          background: linear-gradient(180deg, rgba(20,32,51,.96), rgba(11,18,32,.98));
          border: 1px solid rgba(255,255,255,.12);
          border-radius: 22px;
          padding: 16px;
          box-shadow: 0 16px 38px rgba(0,0,0,.28);
        }

        .admin-match-card.blocked {
          border-color: rgba(239,68,68,.38);
          opacity: .92;
        }

        .admin-match-card.bonus {
          border-color: rgba(34,197,94,.32);
        }

        .admin-match-top {
          display: flex;
          justify-content: space-between;
          align-items: center;
          gap: 10px;
          margin-bottom: 14px;
        }

        .admin-number {
          width: 50px;
          height: 50px;
          border-radius: 16px;
          background: rgba(186,255,0,.16);
          color: #baff00;
          display: grid;
          place-items: center;
          font-size: 24px;
          font-weight: 950;
        }

        .admin-status-btn {
          border-radius: 999px;
          padding: 10px 14px;
          border: 1px solid rgba(34,197,94,.30);
          background: rgba(34,197,94,.14);
          color: #86efac;
          font-size: 13px;
          font-weight: 950;
          cursor: pointer;
        }

        .admin-status-btn.blocked {
          background: rgba(239,68,68,.14);
          color: #fca5a5;
          border-color: rgba(239,68,68,.30);
        }

        .admin-pill {
          border-radius: 999px;
          padding: 8px 12px;
          background: rgba(34,197,94,.14);
          color: #86efac;
          border: 1px solid rgba(34,197,94,.30);
          font-size: 12px;
          font-weight: 950;
        }

        .admin-fields {
          display: grid;
          gap: 10px;
        }

        .admin-fields label {
          display: grid;
          gap: 6px;
          color: #9fb0ca;
          font-size: 12px;
          font-weight: 950;
          text-transform: uppercase;
          letter-spacing: .08em;
        }

        .admin-input {
          width: 100%;
          background: #111827;
          color: #f8fafc;
          border: 1px solid rgba(255,255,255,.14);
          border-radius: 14px;
          padding: 12px 12px;
          font-weight: 900;
          outline: none;
        }

        .admin-input:focus {
          border-color: rgba(186,255,0,.55);
        }

        .admin-two {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 10px;
        }

        .score-row {
          display: flex;
          align-items: center;
          gap: 8px;
        }

        .score-row input {
          text-align: center;
        }

        .admin-card-actions {
          display: flex;
          gap: 8px;
          margin-top: 12px;
        }

        .admin-card-actions button {
          flex: 1;
          border-radius: 999px;
          padding: 12px 14px;
          border: 1px solid rgba(255,255,255,.14);
          background: rgba(255,255,255,.08);
          color: #f8fafc;
          font-weight: 950;
          cursor: pointer;
        }

        .admin-card-actions button.red {
          background: rgba(239,68,68,.18);
          color: #fca5a5;
          border-color: rgba(239,68,68,.30);
        }

        .admin-validate-btn.validated {
          background: rgba(34,197,94,.22) !important;
          border-color: rgba(34,197,94,.65) !important;
          color: #86efac !important;
        }

        @media (max-width: 1200px) {
          .admin-pronos-top {
            grid-template-columns: 1fr;
          }

          .admin-pronos-actions {
            justify-content: flex-start;
          }

          .admin-match-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
          }
        }

        @media (max-width: 760px) {
          .admin-pronos-top {
            padding: 24px;
          }

          .admin-pronos-actions,
          .admin-btn,
          .admin-select {
            width: 100%;
