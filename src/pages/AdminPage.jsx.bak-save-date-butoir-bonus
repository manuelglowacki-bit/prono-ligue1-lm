function loadJson(key, fallback) {
  try {
    const raw = localStorage.getItem(key);
    return raw ? JSON.parse(raw) : fallback;
  } catch {
    return fallback;
  }
}

function savePublicJournees(journees) {
  localStorage.setItem(PUBLIC_JOURNEES_KEY, JSON.stringify(journees));
  localStorage.setItem(STORAGE_KEY, JSON.stringify(journees));
}

function toDateInputValue(value) {
  const raw = String(value || "").trim();

  if (!raw) return "";

  if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) {
    return raw;
  }

  const fr = raw.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);

  if (fr) {
    const day = fr[1].padStart(2, "0");
    const month = fr[2].padStart(2, "0");
    const year = fr[3];
    return `${year}-${month}-${day}`;
  }

  return "";
}

function toTimeInputValue(value) {
  const raw = String(value || "").trim();

  if (!raw) return "";

  const match = raw.match(/(\d{1,2})[:hH](\d{2})/);

  if (match) {
    const hour = match[1].padStart(2, "0");
    const minute = match[2].padStart(2, "0");
    return `${hour}:${minute}`;
  }

  return "";
}

function normalizeJournees(data) {
  if (!Array.isArray(data) || data.length === 0) return DEFAULT_JOURNEES;

  return data.map((j, index) => {
    const journeyId = j.id || `j${index + 1}`;

    return {
      id: journeyId,
      number: j.number || index + 1,
      title: j.title || `J${index + 1}`,
      locked: Boolean(j.locked),
      lockAt: j.lockAt || "",
      matches: Array.isArray(j.matches)
        ? j.matches.map((m, i) => ({
            id: m.id || `${journeyId}-m${i + 1}`,
            home: m.home || "",
            away: m.away || "",
            date: toDateInputValue(m.date) || "",
            time: toTimeInputValue(m.time) || "",
            status: m.status || "Ouvert",
            homeScore: m.homeScore ?? "",
            awayScore: m.awayScore ?? "",
            adminValidated: Boolean(m.adminValidated),
            validated: Boolean(m.validated),
            isValidated: Boolean(m.isValidated),
            result: m.result || m.resultat || "",
            resultat: m.resultat || m.result || ""
          }))
        : [],
      bonus: Array.isArray(j.bonus)
        ? j.bonus.slice(0, 3).map((b, i) => ({
            id: b.id || `${journeyId}-b${i + 1}`,
            league: b.league || "",
            home: b.home || "",
            away: b.away || "",
            date: toDateInputValue(b.date) || "",
            time: toTimeInputValue(b.time) || "",
            homeScore: b.homeScore ?? "",
            awayScore: b.awayScore ?? "",
            adminValidated: Boolean(b.adminValidated),
            validated: Boolean(b.validated),
            isValidated: Boolean(b.isValidated),
            result: b.result || b.resultat || "",
            resultat: b.resultat || b.result || ""
          }))
        : []
    };
  });
}

function makeEmptyBonus(journeyId, index) {
  return {
    id: `${journeyId}-b${index + 1}`,
    league: "",
    home: "",
    away: "",
    date: "",
    time: "",
    homeScore: "",
    awayScore: "",
    adminValidated: false
  };
}

function ensureThreeBonus(journee) {
  const bonus = Array.isArray(journee.bonus) ? [...journee.bonus] : [];

  while (bonus.length < 3) {
    bonus.push(makeEmptyBonus(journee.id, bonus.length));
  }

  return {
    ...journee,
    lockAt: journee.lockAt || "",
    bonus: bonus.slice(0, 3)
  };
}

export default function AdminPage() {
  const fileInputRef = useRef(null);
  const bonusFileInputRef = useRef(null);

  const [journees, setJournees] = useState(() => {
    const saved =
      loadJson(PUBLIC_JOURNEES_KEY, null) ||
      loadJson(STORAGE_KEY, null) ||
      DEFAULT_JOURNEES;

    return normalizeJournees(saved).map(ensureThreeBonus);
  });

  const [selectedJourneeId, setSelectedJourneeId] = useState(() => {
    const saved =
      loadJson(PUBLIC_JOURNEES_KEY, null) ||
      loadJson(STORAGE_KEY, null) ||
      DEFAULT_JOURNEES;

    return normalizeJournees(saved)[0]?.id || "j1";
  });

  const [message, setMessage] = useState("");
  const [bonusRandomStartDate, setBonusRandomStartDate] = useState("");
  const [bonusRandomEndDate, setBonusRandomEndDate] = useState("");

  const selectedJournee = useMemo(() => {
    return (
      journees.find((j) => j.id === selectedJourneeId) ||
      journees[0] ||
      DEFAULT_JOURNEES[0]
    );
  }, [journees, selectedJourneeId]);

  useEffect(() => {
    savePublicJournees(journees);
  }, [journees]);

  function updateSelectedJournee(patch) {
    setJournees((prev) =>
      prev.map((j) =>
        j.id === selectedJournee.id
          ? ensureThreeBonus({ ...j, ...patch })
          : j
      )
    );
  }

  function updateMatch(matchId, patch) {
    const nextMatches = selectedJournee.matches.map((match) =>
      match.id === matchId ? { ...match, ...patch, adminValidated: patch.adminValidated ?? false } : match
    );

    updateSelectedJournee({ matches: nextMatches });
  }

  function updateBonus(bonusId, patch) {
    const currentBonus = ensureThreeBonus(selectedJournee).bonus;

    const nextBonus = currentBonus.map((bonus) =>
      bonus.id === bonusId ? { ...bonus, ...patch, adminValidated: patch.adminValidated ?? false } : bonus
    );

    updateSelectedJournee({ bonus: nextBonus });
  }

  function adminScoreIsFilled(value) {
    return value !== "" && value !== null && value !== undefined;
  }

  function adminToScore(value) {
    if (!adminScoreIsFilled(value)) return "";
    const number = Number(value);
    return Number.isNaN(number) ? "" : number;
  }

  function adminResultFromScore(home, away) {
    if (home > away) return "1";
    if (home < away) return "2";
    return "N";
  }

  function buildAdminValidatedPatch(match) {
    const home = adminToScore(match.homeScore);
    const away = adminToScore(match.awayScore);

    if (!adminScoreIsFilled(home) || !adminScoreIsFilled(away)) {
      return null;
    }

    const resultat = adminResultFromScore(home, away);

    return {
      homeScore: home,
      awayScore: away,
      scoreDomicile: home,
      scoreExterieur: away,
      score: home + "-" + away,
      resultat,
      result: resultat,
      resultatFinal: resultat,
      status: "FINISHED",
      statut: "FINISHED",
      statutLong: "Résultat validé",
      adminValidated: true,
      validated: true,
      isValidated: true,
      resultValidatedAt: new Date().toISOString()
    };
  }

  function validateAdminMatch(matchId) {
    const regularMatch = selectedJournee.matches.find((item) => item.id === matchId);

    if (regularMatch) {
      const patch = buildAdminValidatedPatch(regularMatch);

      if (!patch) {
        alert("Mets le resultat final avant de valider.");
        return;
      }

      const nextMatches = selectedJournee.matches.map((item) =>
        item.id === matchId ? { ...item, ...patch } : item
      );

      updateSelectedJournee({ matches: nextMatches });
      setMessage("Resultat du match valide.");
      return;
    }

    const currentBonus = ensureThreeBonus(selectedJournee).bonus;
    const bonusMatch = currentBonus.find((item) => item.id === matchId);

    if (bonusMatch) {
      const patch = buildAdminValidatedPatch(bonusMatch);

      if (!patch) {
        alert("Mets le resultat final bonus avant de valider.");
        return;
      }

      const nextBonus = currentBonus.map((item) =>
        item.id === matchId ? { ...item, ...patch } : item
      );

      updateSelectedJournee({ bonus: nextBonus });
      setMessage("Resultat bonus valide.");
    }
  }

  function toggleMatchStatus(matchId) {
    const match = selectedJournee.matches.find((m) => m.id === matchId);
    const nextStatus = match?.status === "Bloque" ? "Ouvert" : "Bloque";

    updateMatch(matchId, { status: nextStatus });

    setMessage(nextStatus === "Bloque" ? "Match bloque." : "Match ouvert.");
