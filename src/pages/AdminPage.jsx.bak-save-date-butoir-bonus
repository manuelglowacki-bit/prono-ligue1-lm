          background: #baff00;
          border-color: #baff00;
          color: #07111f;
        }

        .admin-btn.gold {
          background: #ffd21f;
          border-color: #ffd21f;
          color: #07111f;
        }

        .admin-message {
          grid-column: 1 / -1;
          margin-top: 18px;
          padding: 18px 20px;
          border-radius: 18px;
          background: rgba(186,255,0,.08);
          border: 1px solid rgba(186,255,0,.20);
