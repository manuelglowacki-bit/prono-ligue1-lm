            ...j,
            locked: false,
            lockAt: "",
            matches: (j.matches || []).map((m) => ({
              ...m,
              date: toDateInputValue(m.date) || "",
              time: toTimeInputValue(m.time) || "",
              status: m.status || "Ouvert",
              homeScore: m.homeScore || "",
              awayScore: m.awayScore || "",
              adminValidated: false
            })),
            bonus: (j.bonus || []).map((b) => ({
              ...b,
              date: toDateInputValue(b.date) || "",
              time: toTimeInputValue(b.time) || "",
              homeScore: b.homeScore || "",
              awayScore: b.awayScore || "",
              adminValidated: false
            }))
          }))
          .map(ensureThreeBonus);

        if (!imported.length) {
          setMessage("Import impossible : aucune ligne valide trouvee.");
          return;
        }

        setJournees(imported);
        setSelectedJourneeId(imported[0].id);
        savePublicJournees(imported);

