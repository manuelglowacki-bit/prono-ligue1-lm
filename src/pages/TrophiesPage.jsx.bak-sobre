    desc: 'Journées sans aucun mauvais prono.',
    levels: [
      { need: 1, label: '1 journée sans mauvais prono' },
      { need: 2, label: '2 journées sans mauvais prono' },
      { need: 4, label: '4 journées sans mauvais prono' },
      { need: 7, label: '7 journées sans mauvais prono' },
