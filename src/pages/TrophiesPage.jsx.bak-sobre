const SUMMARY = [
  { label: 'Trophées débloqués', value: 7, accent: 'gold' },
  { label: 'Trophées restants', value: 2, accent: 'blue' },
  { label: 'Joueur le plus récompensé', value: 'Laurent', accent: 'cyan' },
];

// current : index du niveau actuel (0..3). -1 = aucun niveau débloqué.
// Si current === 3 (Légende) => prochain niveau = null.
