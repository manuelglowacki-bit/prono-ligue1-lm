// ---------- Icône trophée ----------
function TrophyIcon({ name }) {
  if (name === 'crown') return <Crown size={20} />;
  if (name === 'target') return <Target size={20} />;
  if (name === 'sparkles') return <Sparkles size={20} />;
  if (name === 'trophy') return <Trophy size={20} />;
  if (name === 'heart') return <Heart size={20} />;
  if (name === 'flame') return <Flame size={20} />;
  if (name === 'list') return <ListChecks size={20} />;
  return <Trophy size={20} />;
}

// ---------- Helpers ----------
const TIER_KEYS = ['bronze', 'silver', 'gold', 'legend'];

function getCurrentTier(fam) {
  if (fam.current < 0) return null;
  return TIER_KEYS[fam.current];
}

function getProgressPct(fam) {
  if (fam.current < 0) {
    // locked : on prend le 1er palier comme cible
    const target = fam.levels[0].need;
    if (target <= 0) return 0;
    return Math.max(0, Math.min(100, Math.round((fam.progress / target) * 100)));
  }
  if (fam.current >= 3) return 100;
  const from = fam.current >= 0 ? fam.levels[fam.current].need : 0;
  const to = fam.levels[fam.current + 1].need;
  if (to <= from) return 100;
  const pct = ((fam.progress - from) / (to - from)) * 100;
  return Math.max(0, Math.min(100, Math.round(pct)));
}

// ---------- Carte trophée avec niveaux ----------
function TrophyLevelCard({ fam }) {
  const tier = getCurrentTier(fam);
  const isLocked = !tier;
  const tierKey = tier || 'bronze';
  const tierMeta = TIER_META[tierKey];
  const isMaxed = fam.current === 3;
  const nextIndex = isLocked ? 0 : Math.min(3, fam.current + 1);
  const nextLabel = isMaxed ? null : fam.levels[nextIndex].label;
  const currentLabel = tier
    ? `${tierMeta.medal} ${tierMeta.label}`
    : 'Non débloqué';
  const pct = getProgressPct(fam);
  const ratio = isMaxed
    ? 'Niveau max'
    : `${fam.progress} / ${fam.levels[nextIndex].need}`;
  const [openMobile, setOpenMobile] = useState(false);
  return (
    <div
      className={`trophy-lcard tier-${tierKey} ${isLocked ? 'locked' : ''}`}
      onClick={() => setOpenMobile((v) => !v)}
    >
      <div className="trophy-lcard-head">
        <div className="trophy-lcard-icon">
          {isLocked ? <Lock size={18} /> : <TrophyIcon name={fam.icon} />}
        </div>
        <div className="trophy-lcard-name">{fam.name}</div>
        <div className={`trophy-lcard-tier ${isLocked ? 'tier-locked' : ''}`}>
          <span className="trophy-lcard-medal" aria-hidden="true">
            {isLocked ? '🔒' : tierMeta.medal}
          </span>
          <span className="trophy-lcard-tierlabel">
            {tier ? tierMeta.label : 'Verrouillé'}
          </span>
        </div>
      </div>
      <div className="trophy-lcard-line">
        <span className="trophy-lcard-line-k">Statut</span>
        <span className={`trophy-lcard-line-v ${isLocked ? 'status-locked' : 'status-unlocked'}`}>
          {isLocked ? 'Non débloqué' : 'Débloqué'}
        </span>
      </div>
      <div className="trophy-lcard-line">
        <span className="trophy-lcard-line-k">Niveau actuel</span>
        <span className={`trophy-lcard-line-v ${isLocked ? 'muted' : `tier-tag-${tierKey}`}`}>
          {currentLabel}
        </span>
      </div>
      <div className="trophy-lcard-line">
        <span className="trophy-lcard-line-k">Prochain niveau</span>
        <span className="trophy-lcard-line-v muted">
          {isMaxed ? '— Niveau maximum atteint' : nextLabel}
        </span>
      </div>
      <div className="trophy-lcard-progress">
        <div className="trophy-lcard-bar">
          <div
            className={`trophy-lcard-bar-fill ${isLocked ? 'bar-locked' : `bar-${tierKey}`}`}
            style={{ width: `${pct}%` }}
          />
        </div>
        <span className="trophy-lcard-ratio">{ratio}</span>
      </div>

      {/* Info-bulle — desktop : survol, mobile : tap (toggle) */}
      <div
        className={`trophy-tooltip ${openMobile ? 'mobile-open' : ''}`}
        role="tooltip"
        onClick={(e) => e.stopPropagation()}
      >
        <div className="trophy-tooltip-arrow" aria-hidden="true" />
        <div className="trophy-tooltip-title">{fam.name}</div>
        <p className="trophy-tooltip-text">{fam.desc}</p>
      </div>
    </div>
  );
}

// ---------- Page ----------
export default function TrophiesPage() {
  return (
    <div className="premium-page trophies-page">
      <header className="trophies-header">
        <h1 className="premium-title">Trophées</h1>
        <p className="trophies-subtitle">Récompenses de la {SEASON}</p>
      </header>

      {/* Résumé rapide */}
      <div className="premium-grid three trophies-summary">
        {SUMMARY.map((s) => (
          <div key={s.label} className={`premium-kpi ${s.accent}`}>
            <small>{s.label}</small>
            <b>{s.value}</b>
          </div>
        ))}
      </div>

      {/* Tous les trophées, débloqués et verrouillés affichés ensemble */}
      <div className="premium-card trophies-card">
        <div className="premium-section-title">
          <h2 style={{ margin: 0 }}>Tous les trophées</h2>
          <span>{TROPHY_FAMILIES.filter((f) => f.current >= 0).length}/{TROPHY_FAMILIES.length} débloqués</span>
        </div>
        <div className="trophies-grid">
          {TROPHY_FAMILIES.map((f) => (
            <TrophyLevelCard key={f.key} fam={f} />
          ))}
        </div>
      </div>
    </div>
  );
}
