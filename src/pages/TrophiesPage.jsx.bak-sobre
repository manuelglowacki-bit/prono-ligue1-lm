  },
  {
    key: 'heart',
    icon: 'heart',
    name: 'Cœur fidèle',
    desc: 'Bons pronos sur ton équipe de cœur.',
    levels: [
      { need: 3, label: '3 bons pronos équipe de cœur' },
      { need: 7, label: '7 bons pronos équipe de cœur' },
      { need: 15, label: '15 bons pronos équipe de cœur' },
      { need: 25, label: '25 bons pronos équipe de cœur' },
    ],
    current: 2,
    progress: 15,
  },
  {
    key: 'perfect',
    icon: 'target',
    name: 'Score parfait',
